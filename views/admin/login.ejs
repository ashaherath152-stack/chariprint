<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Chari Fashion Admin</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-login-body">
  <div class="login-box">
    <div class="login-mark">CHAR<span class="spark">✦</span>I</div>
    <p class="login-sub">Admin Dashboard</p>

    <% if (error && error.length) { %>
      <div class="alert alert-error"><%= error[0] %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-field">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required autofocus>
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Log In</button>
    </form>

    <a href="/" class="back-link">← Back to website</a>
  </div>
</body>
</html>
