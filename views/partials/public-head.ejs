<!-- views/partials/public-head.ejs -->
<!-- SEO-friendly head: dynamic title/description per page, Open Graph tags, fonts -->
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<meta name="description" content="<%= metaDescription %>">
<meta name="robots" content="index, follow">
<meta property="og:title" content="<%= title %>">
<meta property="og:description" content="<%= metaDescription %>">
<meta property="og:type" content="website">
<link rel="icon" href="/favicon.ico">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,500&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
