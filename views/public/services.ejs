<!DOCTYPE html>
<html lang="en">
<head>
<%- include('../partials/public-head') %>
</head>
<body>
<%- include('../partials/public-header') %>

<main>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Services</span>
      <h1>What we offer</h1>
    </div>
  </section>

  <section>
    <div class="wrap section-pad">
      <div class="services-grid reveal">
        <div class="service-card">
          <div class="service-icon">✦</div>
          <h3>DTF T-Shirt Printing</h3>
          <p>Full-colour direct-to-film prints on t-shirts of any size, single piece or bulk order.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">✦</div>
          <h3>Custom Designs</h3>
          <p>Send your own artwork, or describe what you want and we'll help shape the design.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">✦</div>
          <h3>Team & Event Orders</h3>
          <p>Matching shirts for events, sports teams, school groups, or company outings.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">✦</div>
          <h3>Business Branding</h3>
          <p>Logo prints for staff uniforms, promotional shirts, and merchandise.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">✦</div>
          <h3>Bulk Pricing</h3>
          <p>Better rates as quantity goes up — ask for a quote on larger orders.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">✦</div>
          <h3>Delivery & Pickup</h3>
          <p>Collect your order or have it delivered, depending on your location.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="dtf">
    <div class="wrap section-pad">
      <div class="section-head reveal">
        <span class="eyebrow">The Process</span>
        <h2>From file to finished shirt</h2>
        <p>Four steps, start to finish. We'll guide you through it on WhatsApp if you're not sure where to begin.</p>
      </div>
      <div class="process-grid reveal">
        <div class="process-step">
          <div class="process-num">01</div>
          <h4>Send Your Design</h4>
          <p>Share your artwork, logo, or idea over WhatsApp. No design yet? We'll help shape it.</p>
        </div>
        <div class="process-step">
          <div class="process-num">02</div>
          <h4>Pick Shirt & Size</h4>
          <p>Choose your shirt colour, fabric, and sizes. We confirm placement and print size with you.</p>
        </div>
        <div class="process-step">
          <div class="process-num">03</div>
          <h4>We Print & Press</h4>
          <p>Your design is printed on film and heat-pressed onto the fabric.</p>
        </div>
        <div class="process-step">
          <div class="process-num">04</div>
          <h4>Collect or Deliver</h4>
          <p>Pick up your order or have it delivered. Bulk orders welcome.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="wrap reveal">
      <h2>Ready to print?</h2>
      <p>Submit your design and quantity, get a quote the same day.</p>
      <a href="/custom-printing" class="btn btn-primary">Start an Order</a>
    </div>
  </section>
</main>

<%- include('../partials/public-footer') %>
</body>
</html>
